# Environment template. Copy to .env and fill in real values.
# NEVER commit the real .env — it is git-ignored.

# --- App ---
ENVIRONMENT=dev
DEBUG=true

# --- Database (matches docker-compose.yml) ---
DATABASE_URL=postgresql+psycopg2://ruthere:ruthere@localhost:5432/ruthere

# --- Auth (generate a strong random secret in production) ---
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Resend (email verification) ---
# Fill RESEND_API_KEY with a NEW key after revoking the one leaked in the PRD.
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@lwytool.com
EMAIL_CODE_LENGTH=6
EMAIL_CODE_EXPIRE_MINUTES=10
RESEND_COOLDOWN_SECONDS=60

# --- Activity decay / offline ---
DECAY_INTERVAL_MINUTES=10
OFFLINE_THRESHOLD_HOURS=12

# --- Admin ---
ADMIN_API_KEY=
